{
  "manifest_version": 3,
  "name": "TemTradução",
  "description": "Traduz o texto selecionado com um popup configurável e balão inline abaixo da seleção.",
  "version": "0.1.0",
  "icons": {
    "16": "download__1_-removebg-preview.png",
    "32": "download__1_-removebg-preview.png",
    "48": "download__1_-removebg-preview.png",
    "128": "download__1_-removebg-preview.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.datamuse.com/*"
  ],
  "action": {
    "default_title": "TemTradução",
    "default_popup": "index.html",
    "default_icon": {
      "16": "download__1_-removebg-preview.png",
      "32": "download__1_-removebg-preview.png",
      "48": "download__1_-removebg-preview.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
